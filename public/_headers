# Cabeceras para Cloudflare Pages
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains

# Assets con hash de contenido (Astro los versiona) → cache inmutable
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Media estática optimizada
/avatar/*
  Cache-Control: public, max-age=2592000
/banner/*
  Cache-Control: public, max-age=2592000
/certs/*
  Cache-Control: public, max-age=2592000

# Diagramas: se regeneran sólo si cambia el .mmd de origen
/blog/diagrams/*
  Cache-Control: public, max-age=2592000
  Content-Type: image/svg+xml

# El CV y el OG cambian poco pero deben poder invalidarse
/cv/*
  Cache-Control: public, max-age=86400
/og.jpg
  Cache-Control: public, max-age=604800

# Feeds: frescos pero cacheables en el borde
/rss.xml
  Cache-Control: public, max-age=3600
  Content-Type: application/rss+xml; charset=utf-8
/sitemap-index.xml
  Cache-Control: public, max-age=3600
/sitemap-0.xml
  Cache-Control: public, max-age=3600
