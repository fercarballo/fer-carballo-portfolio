---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import { getCollection } from 'astro:content';
import { groupByCluster } from '../../data/blog';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const groups = groupByCluster(posts);
const baseGroups = groups.filter((g) => g.cluster.series === 'base');
const advGroups = groups.filter((g) => g.cluster.series === 'avanzada');
const agGroups = groups.filter((g) => g.cluster.series === 'agentes');

const totalArticles = posts.length;
const totalClusters = groups.length;
const totalPillars = posts.filter((p) => p.data.type === 'pilar').length;

// Cada serie tiene su puerta de entrada: el pilar de su capítulo 00 (el mapa).
const entry = groups.find((g) => g.cluster.id === '00')?.pillar;
const entryAdv = groups.find((g) => g.cluster.id === 'a00')?.pillar;
const entryAg = groups.find((g) => g.cluster.id === 'g00')?.pillar;

const site = Astro.site!.href.replace(/\/$/, '');
const blogSchema = {
  '@type': 'Blog',
  '@id': `${site}/blog/#blog`,
  url: `${site}/blog/`,
  name: 'Blog de Quality Engineering',
  description: `Corpus de ${totalArticles} artículos de Quality Engineering y SDET, organizados en ${totalClusters} colecciones pilar-satélite.`,
  inLanguage: 'es-AR',
  author: { '@id': `${site}/#fernando` },
  publisher: { '@id': `${site}/#fernando` },
  isPartOf: { '@id': `${site}/#website` },
  // Sólo los pilares: son las entradas canónicas de cada colección.
  blogPost: groups.map((g) => ({
    '@type': 'TechArticle',
    '@id': `${site}/blog/${g.pillar.id}/#article`,
    url: `${site}/blog/${g.pillar.id}/`,
    headline: g.pillar.data.title,
    datePublished: g.pillar.data.pubDate.toISOString(),
    author: { '@id': `${site}/#fernando` },
  })),
};
---

<Base
  title="Blog de Quality Engineering — Fernando Carballo"
  description="Corpus de Quality Engineering y SDET: arquitectura de calidad, contract testing, CI/CD, performance, observabilidad, seguridad, accesibilidad, resiliencia, fintech e IA. Artículos con evidencia citada y código público."
  breadcrumbs={[{ name: 'Inicio', url: '/' }, { name: 'Blog' }]}
  schema={blogSchema}
>
  <main class="container blog">
    <header class="blog-hero">
      <span class="kicker">Blog técnico</span>
      <h1>Quality Engineering, de la teoría a la evidencia</h1>
      <p>
        Un corpus de {totalArticles} artículos en {totalClusters} colecciones, organizado en tres series:
        <strong>fundamentos</strong> ({baseGroups.length} colecciones), la <strong>serie avanzada</strong> ({advGroups.length} capítulos
        sobre event-driven, supply chain, privacy, data quality y plataforma) y la <strong>serie de agentes de IA</strong>
        ({agGroups.length} capítulos: arquitecturas, MCP, evaluación y seguridad de agentes). Cada colección abre con un
        <strong>pilar</strong> y se profundiza en <strong>satélites</strong>, siempre con la evidencia citada y
        lo no verificado rotulado como tal.
      </p>

      <ul class="blog-stats">
        <li><strong>{totalArticles}</strong><span>artículos</span></li>
        <li><strong>{totalClusters}</strong><span>colecciones</span></li>
        <li><strong>{totalPillars}</strong><span>pilares</span></li>
        <li><strong>7</strong><span>repos de soporte</span></li>
      </ul>
    </header>

    <div class="blog-entries">
      {
        entry && (
          <a class="blog-entry card" href={`/blog/${entry.id}/`} data-reveal data-tilt>
            <span class="blog-entry__icon"><Icon name="grad" size={22} /></span>
            <div class="blog-entry__text">
              <span class="blog-entry__kicker">Empezá acá · fundamentos</span>
              <h2>{entry.data.title}</h2>
              <p>{entry.data.description}</p>
            </div>
            <span class="blog-entry__arrow"><Icon name="arrow-right" size={18} /></span>
          </a>
        )
      }
      {
        entryAdv && (
          <a class="blog-entry blog-entry--adv card" href={`/blog/${entryAdv.id}/`} data-reveal data-tilt>
            <span class="blog-entry__icon blog-entry__icon--adv"><Icon name="command" size={22} /></span>
            <div class="blog-entry__text">
              <span class="blog-entry__kicker blog-entry__kicker--adv">Serie avanzada · el mapa</span>
              <h2>{entryAdv.data.title}</h2>
              <p>{entryAdv.data.description}</p>
            </div>
            <span class="blog-entry__arrow"><Icon name="arrow-right" size={18} /></span>
          </a>
        )
      }
      {
        entryAg && (
          <a class="blog-entry blog-entry--ag card" href={`/blog/${entryAg.id}/`} data-reveal data-tilt>
            <span class="blog-entry__icon blog-entry__icon--ag"><Icon name="bot" size={22} /></span>
            <div class="blog-entry__text">
              <span class="blog-entry__kicker blog-entry__kicker--ag">Serie de agentes · el mapa</span>
              <h2>{entryAg.data.title}</h2>
              <p>{entryAg.data.description}</p>
            </div>
            <span class="blog-entry__arrow"><Icon name="arrow-right" size={18} /></span>
          </a>
        )
      }
    </div>

    <section class="blog-section" aria-labelledby="colecciones">
      <div class="section-head" data-reveal>
        <div>
          <span class="kicker">Serie fundamentos</span>
          <h2 id="colecciones">Las {baseGroups.length} rutas de la serie base</h2>
          <p class="blog-section__sub">
            Cada tarjeta es una ruta de lectura completa: un pilar y sus satélites, en orden.
          </p>
        </div>
      </div>

      <div class="cluster-grid">
        {
          baseGroups.map((g, i) => (
            <a
              class="cluster-card card"
              href={`/blog/coleccion/${g.cluster.id}/`}
              data-tilt
              data-reveal
              style={`--hue: ${g.cluster.hue}; --d: ${(i % 3) * 0.05}s`}
            >
              <header class="cluster-card__head">
                <span class="cluster-card__icon">
                  <Icon name={g.cluster.icon} size={20} />
                </span>
                <span class="cluster-card__num">{g.cluster.id}</span>
              </header>

              <h3>{g.cluster.title}</h3>
              <p class="cluster-card__blurb">{g.cluster.blurb}</p>

              <p class="cluster-card__pillar">
                <span class="badge badge--pilar">Pilar</span>
                <span>{g.pillar.data.title}</span>
              </p>

              <footer class="cluster-card__foot">
                <span class="cluster-card__count">
                  {g.items.length} {g.items.length === 1 ? 'artículo' : 'artículos'}
                </span>
                <span class="cluster-card__go">
                  Ver colección <Icon name="arrow-right" size={14} />
                </span>
              </footer>
            </a>
          ))
        }
      </div>
    </section>

    <section class="blog-section" aria-labelledby="avanzada">
      <div class="section-head" data-reveal>
        <div>
          <span class="kicker">Serie avanzada</span>
          <h2 id="avanzada">Los {advGroups.length} capítulos avanzados</h2>
          <p class="blog-section__sub">
            La continuación senior de los fundamentos: sistemas asíncronos, cadena de suministro, privacidad,
            datos, plataforma y el capstone que integra todo. Dominio ficticio Nexo Finanzas, evidencia rotulada.
          </p>
        </div>
      </div>

      <div class="cluster-grid">
        {
          advGroups.map((g, i) => (
            <a
              class="cluster-card card"
              href={`/blog/coleccion/${g.cluster.id}/`}
              data-tilt
              data-reveal
              style={`--hue: ${g.cluster.hue}; --d: ${(i % 3) * 0.05}s`}
            >
              <header class="cluster-card__head">
                <span class="cluster-card__icon">
                  <Icon name={g.cluster.icon} size={20} />
                </span>
                <span class="cluster-card__num">{g.cluster.id.slice(1)}</span>
              </header>

              <h3>{g.cluster.title}</h3>
              <p class="cluster-card__blurb">{g.cluster.blurb}</p>

              <p class="cluster-card__pillar">
                <span class="badge badge--pilar">Pilar</span>
                <span>{g.pillar.data.title}</span>
              </p>

              <footer class="cluster-card__foot">
                <span class="cluster-card__count">
                  {g.items.length} {g.items.length === 1 ? 'artículo' : 'artículos'}
                </span>
                <span class="cluster-card__go">
                  Ver capítulo <Icon name="arrow-right" size={14} />
                </span>
              </footer>
            </a>
          ))
        }
      </div>
    </section>

    <section class="blog-section" aria-labelledby="agentes">
      <div class="section-head" data-reveal>
        <div>
          <span class="kicker">Serie de agentes de IA</span>
          <h2 id="agentes">Los {agGroups.length} capítulos agénticos</h2>
          <p class="blog-section__sub">
            Sistemas que actúan solos exigen otra disciplina de calidad: arquitecturas y sus modos de fallo,
            herramientas y MCP, evaluación de trayectorias, seguridad y los agentes aplicados a QA.
            Anclado a repos de referencia reales.
          </p>
        </div>
      </div>

      <div class="cluster-grid">
        {
          agGroups.map((g, i) => (
            <a
              class="cluster-card card"
              href={`/blog/coleccion/${g.cluster.id}/`}
              data-tilt
              data-reveal
              style={`--hue: ${g.cluster.hue}; --d: ${(i % 3) * 0.05}s`}
            >
              <header class="cluster-card__head">
                <span class="cluster-card__icon">
                  <Icon name={g.cluster.icon} size={20} />
                </span>
                <span class="cluster-card__num">{g.cluster.id.slice(1)}</span>
              </header>

              <h3>{g.cluster.title}</h3>
              <p class="cluster-card__blurb">{g.cluster.blurb}</p>

              <p class="cluster-card__pillar">
                <span class="badge badge--pilar">Pilar</span>
                <span>{g.pillar.data.title}</span>
              </p>

              <footer class="cluster-card__foot">
                <span class="cluster-card__count">
                  {g.items.length} {g.items.length === 1 ? 'artículo' : 'artículos'}
                </span>
                <span class="cluster-card__go">
                  Ver capítulo <Icon name="arrow-right" size={14} />
                </span>
              </footer>
            </a>
          ))
        }
      </div>
    </section>

    <section class="blog-section" aria-labelledby="indice">
      <div class="section-head" data-reveal>
        <div>
          <span class="kicker">Índice completo</span>
          <h2 id="indice">Los {totalArticles} artículos, en orden de lectura</h2>
        </div>
      </div>

      <div class="index-cols">
        {
          groups.map((g) => (
            <div class="index-block" data-reveal style={`--hue: ${g.cluster.hue}`}>
              <h3 class="index-block__title">
                <span class="index-block__num">{g.cluster.id}</span>
                <a href={`/blog/coleccion/${g.cluster.id}/`}>{g.cluster.short}</a>
              </h3>
              <ol class="index-list">
                {g.items.map((p) => (
                  <li>
                    <a href={`/blog/${p.id}/`}>
                      {p.data.type === 'pilar' && <span class="dot" aria-label="Pilar" />}
                      {p.data.title}
                    </a>
                  </li>
                ))}
              </ol>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Base>

<style>
  .blog {
    padding-top: 60px;
  }

  .blog-hero {
    max-width: 760px;
  }

  .blog-hero h1 {
    font-size: clamp(30px, 5vw, 46px);
    margin-top: 8px;
    line-height: 1.1;
  }

  .blog-hero p {
    margin-top: 18px;
    font-size: 15.5px;
    color: var(--text-2);
    line-height: 1.75;
  }

  .blog-hero strong {
    color: var(--text);
    font-weight: 600;
  }

  .blog-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 28px;
    margin: 28px 0 0;
    padding: 0;
    list-style: none;
  }

  .blog-stats li {
    display: flex;
    flex-direction: column;
  }

  .blog-stats strong {
    font-size: 26px;
    font-weight: 750;
    color: var(--accent-hover);
    font-variant-numeric: tabular-nums;
  }

  .blog-stats span {
    font-size: 12.5px;
    color: var(--text-3);
  }

  /* ── Puntos de entrada (uno por serie) ── */
  .blog-entries {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 16px;
    margin-top: 40px;
  }

  .blog-entries .blog-entry {
    margin-top: 0;
  }

  .blog-entry--adv {
    border-color: rgba(94, 198, 255, 0.3);
    background: linear-gradient(120deg, rgba(47, 127, 208, 0.15), var(--card) 60%);
  }

  .blog-entry__icon--adv {
    background: #2f7fd0;
  }

  .blog-entry__kicker--adv {
    color: var(--cyan);
  }

  .blog-entry--adv .blog-entry__arrow {
    color: var(--cyan);
  }

  .blog-entry--ag {
    border-color: rgba(255, 122, 89, 0.3);
    background: linear-gradient(120deg, rgba(210, 90, 60, 0.14), var(--card) 60%);
  }

  .blog-entry__icon--ag {
    background: #c65a3a;
  }

  .blog-entry__kicker--ag {
    color: var(--poppy);
  }

  .blog-entry--ag .blog-entry__arrow {
    color: var(--poppy);
  }

  /* ── Punto de entrada ── */
  .blog-entry {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-top: 40px;
    padding: 24px 26px;
    border-radius: var(--r-lg);
    border-color: rgba(70, 209, 126, 0.3);
    background: linear-gradient(120deg, rgba(34, 160, 90, 0.14), var(--card) 60%);
    color: inherit;
  }

  .blog-entry__icon {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    border-radius: 15px;
    background: var(--accent);
    color: #fff;
  }

  .blog-entry__kicker {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--accent-hover);
  }

  .blog-entry__text h2 {
    margin-top: 5px;
    font-size: 19px;
    line-height: 1.3;
  }

  .blog-entry__text p {
    margin-top: 7px;
    font-size: 13.5px;
    color: var(--text-2);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-entry__arrow {
    margin-left: auto;
    flex-shrink: 0;
    color: var(--accent-hover);
    transition: transform 0.2s;
  }

  .blog-entry:hover .blog-entry__arrow {
    transform: translateX(5px);
  }

  /* ── Secciones ── */
  .blog-section {
    margin-top: 80px;
  }

  .blog-section__sub {
    margin-top: 6px;
    font-size: 13.5px;
    color: var(--text-3);
  }

  /* ── Grilla de colecciones ── */
  .cluster-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 18px;
  }

  .cluster-card {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 22px;
    border-radius: var(--r-lg);
    color: inherit;
  }

  .cluster-card:hover {
    border-color: hsl(var(--hue) 60% 45% / 0.5);
  }

  .cluster-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .cluster-card__icon {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: hsl(var(--hue) 55% 50% / 0.14);
    border: 1px solid hsl(var(--hue) 60% 55% / 0.3);
    color: hsl(var(--hue) 70% 66%);
  }

  .cluster-card__num {
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-3);
    opacity: 0.5;
  }

  .cluster-card h3 {
    font-size: 16.5px;
    line-height: 1.35;
    font-weight: 650;
  }

  .cluster-card:hover h3 {
    color: var(--accent-hover);
  }

  .cluster-card__blurb {
    font-size: 13px;
    line-height: 1.6;
    color: var(--text-2);
  }

  .cluster-card__pillar {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    font-size: 12.5px;
    color: var(--text-3);
    line-height: 1.5;
    padding-top: 12px;
    border-top: 1px solid var(--border);
  }

  .cluster-card__foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 6px;
  }

  .cluster-card__count {
    font-size: 12px;
    color: var(--text-3);
    font-variant-numeric: tabular-nums;
  }

  .cluster-card__go {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--accent-hover);
  }

  /* ── Índice completo ── */
  .index-cols {
    columns: 3 300px;
    column-gap: 34px;
  }

  .index-block {
    break-inside: avoid;
    margin-bottom: 30px;
  }

  .index-block__title {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 14px;
    font-weight: 650;
    margin-bottom: 10px;
  }

  .index-block__title a:hover {
    color: var(--accent-hover);
  }

  .index-block__num {
    font-family: var(--mono);
    font-size: 11.5px;
    color: hsl(var(--hue) 70% 66%);
  }

  .index-list {
    margin: 0;
    padding: 0 0 0 4px;
    list-style: none;
    display: grid;
    gap: 7px;
    border-left: 1px solid var(--border);
  }

  .index-list li a {
    display: flex;
    align-items: baseline;
    gap: 8px;
    padding-left: 12px;
    font-size: 12.8px;
    line-height: 1.5;
    color: var(--text-2);
  }

  .index-list li a:hover {
    color: var(--accent-hover);
  }

  .dot {
    flex-shrink: 0;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent-hover);
    transform: translateY(-2px);
  }
</style>
