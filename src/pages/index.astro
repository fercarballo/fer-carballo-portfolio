---
import Base from '../layouts/Base.astro';
import HeroBanner from '../components/HeroBanner.astro';
import ProfileCard from '../components/ProfileCard.astro';
import ProjectsSidebar from '../components/ProjectsSidebar.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import ProcessSection from '../components/ProcessSection.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import CertificationsSection from '../components/CertificationsSection.astro';
import PresenceSection from '../components/PresenceSection.astro';
import ContactSection from '../components/ContactSection.astro';
import BlogCard from '../components/BlogCard.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/profile';

// El blog es un corpus por colecciones, no un feed cronolĂ³gico: en la home
// mostramos los primeros pilares (las puertas de entrada), no "lo mĂ¡s nuevo".
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .filter((p) => p.data.type === 'pilar')
  .sort((a, b) => a.data.cluster.localeCompare(b.data.cluster))
  .slice(0, 3);
const totalPosts = allPosts.length;
const totalClusters = new Set(allPosts.map((p) => p.data.cluster)).size;

/**
 * La home es, literalmente, la pĂ¡gina de perfil de una persona: `ProfilePage`
 * con `mainEntity` apuntando al nodo Person del @graph. Los proyectos van como
 * ItemList de SoftwareSourceCode, que es lo que realmente son (repos pĂºblicos).
 */
const site = Astro.site!.href.replace(/\/$/, '');
const homeSchema = [
  {
    '@type': 'ProfilePage',
    '@id': `${site}/#profilepage`,
    url: `${site}/`,
    inLanguage: 'es-AR',
    isPartOf: { '@id': `${site}/#website` },
    mainEntity: { '@id': `${site}/#fernando` },
    about: { '@id': `${site}/#fernando` },
  },
  {
    '@type': 'ItemList',
    '@id': `${site}/#proyectos`,
    name: 'Proyectos pĂºblicos de Fernando Carballo',
    numberOfItems: projects.length,
    itemListElement: projects.map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'SoftwareSourceCode',
        name: p.title,
        description: p.summary,
        url: p.repo,
        codeRepository: p.repo,
        programmingLanguage: p.tags,
        author: { '@id': `${site}/#fernando` },
      },
    })),
  },
];
---

<Base schema={homeSchema}>
  <main id="top" class="container">
    <HeroBanner />

    <div class="layout">
      <div class="layout__side">
        <ProfileCard />
        <ProjectsSidebar />
      </div>
      <div class="layout__main">
        <ExperienceSection embedded />
      </div>
    </div>
  </main>

  <CertificationsSection />
  <ProjectsGrid standalone />
  <PresenceSection />
  <ProcessSection />

  <section class="blog-preview container">
    <div class="section-head" data-reveal>
      <div>
        <span class="kicker">Blog tĂ©cnico</span>
        <h2>Quality Engineering, por colecciones</h2>
        <p class="blog-preview__sub">
          {totalPosts} artĂ­culos en {totalClusters} colecciones. Cada una abre con un pilar.
        </p>
      </div>
      <a class="blog-preview__all" href="/blog">
        Ver el corpus <Icon name="arrow-right" size={15} />
      </a>
    </div>
    <div class="blog-preview__grid">
      {posts.map((post, i) => <BlogCard post={post} index={i} />)}
    </div>
  </section>

  <ContactSection />
</Base>

<style>
  main {
    padding-top: 24px;
  }

  .layout {
    display: grid;
    /* minmax(0, â€¦) evita que el min-content de las tabs infle la columna */
    grid-template-columns: 352px minmax(0, 1fr);
    gap: 26px;
    margin-top: 0;
    align-items: start;
  }

  .layout__side {
    position: relative;
    z-index: 2;
  }

  .layout__main {
    padding-top: 26px;
  }

  @media (max-width: 980px) {
    .layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .layout__main {
      padding-top: 0;
      margin-top: 30px;
    }
  }

  .blog-preview {
    margin-top: 90px;
  }

  .blog-preview__sub {
    margin-top: 6px;
    font-size: 13.5px;
    color: var(--text-3);
  }

  .blog-preview__all {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13.5px;
    font-weight: 550;
    color: var(--accent-hover);
    white-space: nowrap;
  }

  .blog-preview__all:hover {
    color: var(--cyan);
  }

  .blog-preview__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 18px;
  }
</style>
