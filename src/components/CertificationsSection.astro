---
import Icon from './Icon.astro';
import { certifications, moreCertifications } from '../data/profile';
---

<div id="certificaciones" class="certs container">
  <div class="section-head" data-reveal>
    <div>
      <span class="kicker">Formación</span>
      <h2>Certificaciones verificables</h2>
      <p class="certs__sub">
        Documentos oficiales — tocá cualquier tarjeta para abrir el certificado original en PDF.
      </p>
    </div>
    <div class="certs__nav">
      <button class="certs__arrow" data-cert-prev aria-label="Anteriores">
        <Icon name="arrow-right" size={16} style="transform: rotate(180deg)" />
      </button>
      <button class="certs__arrow" data-cert-next aria-label="Siguientes">
        <Icon name="arrow-right" size={16} />
      </button>
    </div>
  </div>

  <div class="certs__rail" data-cert-rail data-reveal>
    {
      certifications.map((cert, i) => (
        <a
          class="certs__card card"
          href={cert.pdf}
          target="_blank"
          rel="noopener"
          data-tilt
          style={`--d: ${i * 0.04}s`}
        >
          <figure class="certs__thumb">
            <img
              src={cert.thumb}
              alt={`Certificado: ${cert.title}`}
              loading="lazy"
              decoding="async"
              width="280"
              height="198"
            />
            <span class="certs__open">
              <Icon name="arrow-right" size={13} /> Ver PDF
            </span>
          </figure>
          <div class="certs__meta">
            <span class="certs__badges">
              <span class="certs__year">{cert.year}</span>
              {cert.tag && <span class={`certs__tag certs__tag--${cert.tag.toLowerCase()}`}>{cert.tag}</span>}
            </span>
            <h3>{cert.title}</h3>
            <p>{cert.issuer}</p>
          </div>
        </a>
      ))
    }
  </div>

  <div class="certs__more" data-reveal>
    {
      moreCertifications.map((cert) => (
        <span class="chip chip--outline certs__more-chip" title={cert.issuer}>
          {cert.title} · <em>{cert.issuer}</em> · {cert.year}
        </span>
      ))
    }
  </div>

</div>

<script>
  function initCertRail() {
    const rail = document.querySelector<HTMLElement>('[data-cert-rail]');
    if (!rail) return;
    const step = () => {
      const card = rail.querySelector<HTMLElement>('.certs__card');
      return card ? card.offsetWidth + 16 : 320;
    };
    document.querySelector('[data-cert-prev]')?.addEventListener('click', () => {
      rail.scrollBy({ left: -step() * 2, behavior: 'smooth' });
    });
    document.querySelector('[data-cert-next]')?.addEventListener('click', () => {
      rail.scrollBy({ left: step() * 2, behavior: 'smooth' });
    });
  }
  initCertRail();
  document.addEventListener('astro:page-load', initCertRail);
</script>

<style>
  .certs {
    margin-top: 90px;
  }

  .certs__sub {
    margin-top: 6px;
    font-size: 13.5px;
    color: var(--text-3);
  }

  .certs__nav {
    display: flex;
    gap: 8px;
  }

  .certs__arrow {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: var(--r-full);
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--text-2);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, transform 0.15s;
  }

  .certs__arrow:hover {
    border-color: var(--accent);
    color: var(--accent-hover);
    transform: translateY(-1px);
  }

  /* ── Pasarela ─────────────────────────────── */
  .certs__rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 280px;
    gap: 16px;
    overflow-x: auto;
    padding: 6px 6px 18px;
    margin: 0 -6px;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
    -webkit-overflow-scrolling: touch;
  }

  .certs__card {
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    padding: 10px 10px 16px;
    border-radius: var(--r-lg);
    color: inherit;
    text-decoration: none;
  }

  .certs__thumb {
    position: relative;
    margin: 0 0 12px;
    border-radius: calc(var(--r-lg) - 6px);
    overflow: hidden;
    border: 1px solid var(--border);
    aspect-ratio: 297 / 210;
    background: #0b0e14;
  }

  .certs__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .certs__card:hover .certs__thumb img {
    transform: scale(1.045);
  }

  .certs__open {
    position: absolute;
    right: 8px;
    bottom: 8px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 11px;
    font-weight: 600;
    padding: 5px 10px;
    border-radius: var(--r-full);
    background: rgba(10, 13, 20, 0.78);
    border: 1px solid var(--border);
    color: var(--text);
    backdrop-filter: blur(6px);
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.25s, transform 0.25s;
  }

  .certs__card:hover .certs__open,
  .certs__card:focus-visible .certs__open {
    opacity: 1;
    transform: translateY(0);
  }

  .certs__meta {
    padding: 0 6px;
  }

  .certs__badges {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-bottom: 9px;
  }

  .certs__year {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    padding: 3px 10px;
    border-radius: var(--r-full);
    background: var(--accent-soft);
    color: var(--accent-hover);
    font-weight: 600;
  }

  .certs__tag {
    font-size: 10.5px;
    font-weight: 650;
    letter-spacing: 0.04em;
    padding: 3px 9px;
    border-radius: var(--r-full);
    border: 1px solid var(--border);
    color: var(--text-2);
  }

  .certs__tag--qa {
    border-color: rgba(64, 217, 156, 0.35);
    color: #4bdca4;
  }

  .certs__tag--ia {
    border-color: rgba(186, 122, 255, 0.35);
    color: #c093f5;
  }

  .certs__tag--seguridad {
    border-color: rgba(255, 176, 64, 0.35);
    color: #ffb95e;
  }

  .certs__card h3 {
    font-size: 13.5px;
    font-weight: 620;
    line-height: 1.4;
  }

  .certs__card p {
    margin-top: 5px;
    font-size: 12px;
    color: var(--text-3);
  }

  /* ── Otras certificaciones ─────────────────── */
  .certs__more {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .certs__more-chip {
    font-size: 11.5px;
  }

  .certs__more-chip em {
    font-style: normal;
    color: var(--text-3);
  }

  @media (max-width: 640px) {
    .certs__rail {
      grid-auto-columns: 240px;
    }
  }
</style>
