---
import Icon from './Icon.astro';

const steps = [
  {
    icon: 'book',
    title: 'Requerimiento',
    desc: 'Criterios de aceptación claros y alcance documentado junto a producto y desarrollo.',
  },
  {
    icon: 'flask',
    title: 'Diseño de pruebas',
    desc: 'Casos funcionales, de regresión e integración priorizados por riesgo e impacto.',
  },
  {
    icon: 'bot',
    title: 'Automatización',
    desc: 'Flujos críticos automatizados con Cypress y Playwright; APIs validadas con Postman.',
  },
  {
    icon: 'infinity',
    title: 'CI/CD',
    desc: 'La suite corre en cada merge request: quality gates que bloquean regresiones.',
  },
  {
    icon: 'ship',
    title: 'Despliegue',
    desc: 'GitOps con ArgoCD sobre Kubernetes/OpenShift, con observabilidad y rollback.',
  },
];
---

<section id="proceso" class="process container">
  <div class="section-head" data-reveal>
    <div>
      <span class="kicker">Cómo trabajo</span>
      <h2>Calidad end-to-end: del requerimiento al despliegue</h2>
    </div>
  </div>

  <div class="process__grid">
    <ol class="process__steps">
      {
        steps.map((s, i) => (
          <li class="process__step card" data-reveal style={`--d: ${i * 0.07}s`}>
            <span class="process__num">0{i + 1}</span>
            <span class="process__icon">
              <Icon name={s.icon} size={20} />
            </span>
            <div>
              <h3>{s.title}</h3>
              <p>{s.desc}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="terminal card" data-reveal style="--d: 0.15s" id="qa-terminal">
      <div class="terminal__bar">
        <span class="terminal__dot" style="--c: #ff5f57"></span>
        <span class="terminal__dot" style="--c: #febc2e"></span>
        <span class="terminal__dot" style="--c: #28c840"></span>
        <span class="terminal__title">fer@qa — pipeline</span>
      </div>
      <pre class="terminal__body" id="terminal-body" aria-label="Demostración de suite de pruebas"><span class="t-prompt">$</span> <span id="terminal-cursor" class="t-cursor"></span></pre>
    </div>
  </div>
</section>

<style>
  .process {
    margin-top: 90px;
  }

  .process__grid {
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 18px;
    align-items: start;
  }

  @media (max-width: 980px) {
    .process__grid {
      grid-template-columns: 1fr;
    }
  }

  .process__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 12px;
  }

  .process__step {
    display: flex;
    align-items: flex-start;
    gap: 15px;
    padding: 16px 18px;
    border-radius: var(--r-md);
  }

  .process__num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-3);
    padding-top: 4px;
  }

  .process__icon {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 12px;
    background: var(--accent-soft);
    color: var(--accent-hover);
  }

  .process__step h3 {
    font-size: 14.5px;
    font-weight: 640;
  }

  .process__step p {
    margin-top: 3px;
    font-size: 13px;
    color: var(--text-2);
    line-height: 1.55;
  }

  /* ── Terminal ── */
  .terminal {
    position: sticky;
    top: 90px;
    border-radius: var(--r-lg);
    overflow: hidden;
    background: #0c0c10;
  }

  .terminal__bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 16px;
    background: #17171c;
    border-bottom: 1px solid var(--border);
  }

  .terminal__dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--c);
  }

  .terminal__title {
    margin-left: 10px;
    font-family: var(--mono);
    font-size: 11.5px;
    color: var(--text-3);
  }

  .terminal__body {
    margin: 0;
    padding: 18px;
    min-height: 320px;
    font-family: var(--mono);
    font-size: 12.3px;
    line-height: 1.75;
    color: #cfd3dc;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .terminal__body :global(.t-prompt) {
    color: var(--cyan);
    font-weight: 700;
  }

  .terminal__body :global(.t-cmd) {
    color: #e8eaf0;
  }

  .terminal__body :global(.t-dim) {
    color: #62626e;
  }

  .terminal__body :global(.t-pass) {
    color: var(--green);
    font-weight: 600;
  }

  .terminal__body :global(.t-info) {
    color: #6ea8ff;
  }

  .t-cursor {
    display: inline-block;
    width: 8px;
    height: 15px;
    vertical-align: -2px;
    background: var(--cyan);
    animation: blink 1.1s steps(1) infinite;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }
</style>

<script>
  // Terminal animada: tipea el comando y "corre" la suite con líneas PASS
  const SCRIPT_LINES: Array<{ text: string; cls?: string; delay: number }> = [
    { text: 'npx playwright test --project=chromium', cls: 't-cmd', delay: 55 },
    { text: '', delay: 300 },
    { text: 'Running 24 tests using 4 workers', cls: 't-dim', delay: 0 },
    { text: '', delay: 350 },
    { text: '  ✓ auth/login.spec.ts › credenciales válidas (1.2s)', cls: 't-pass', delay: 0 },
    { text: '  ✓ auth/login.spec.ts › bloqueo tras 3 intentos (0.9s)', cls: 't-pass', delay: 0 },
    { text: '  ✓ api/contracts.spec.ts › schema y status 200 (0.4s)', cls: 't-pass', delay: 0 },
    { text: '  ✓ checkout/flow.spec.ts › compra end-to-end (2.8s)', cls: 't-pass', delay: 0 },
    { text: '  ✓ regression/critical-path.spec.ts › smoke suite (1.6s)', cls: 't-pass', delay: 0 },
    { text: '', delay: 250 },
    { text: '  24 passed (11.3s)', cls: 't-pass', delay: 0 },
    { text: '', delay: 400 },
    { text: '→ Pipeline: build ✓  test ✓  image ✓  deploy → OpenShift', cls: 't-info', delay: 0 },
    { text: '→ ArgoCD: sync OK · estado deseado = Git', cls: 't-info', delay: 0 },
  ];

  function initTerminal() {
    const body = document.getElementById('terminal-body');
    const term = document.getElementById('qa-terminal');
    if (!body || !term || term.dataset.init) return;
    term.dataset.init = '1';

    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    function renderAll() {
      body!.innerHTML =
        '<span class="t-prompt">$</span> ' +
        SCRIPT_LINES.map((l) => `<span class="${l.cls ?? ''}">${l.text}</span>`).join('\n');
    }

    if (reduced) {
      renderAll();
      return;
    }

    let started = false;

    async function play() {
      if (started) return;
      started = true;
      const cursor = document.getElementById('terminal-cursor');

      const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

      // 1. Tipear el comando letra por letra
      const cmd = SCRIPT_LINES[0];
      const cmdSpan = document.createElement('span');
      cmdSpan.className = cmd.cls ?? '';
      cursor?.before(cmdSpan);
      for (const ch of cmd.text) {
        cmdSpan.textContent += ch;
        await sleep(cmd.delay + Math.random() * 30);
      }
      await sleep(500);

      // 2. Imprimir el resto línea a línea
      for (const line of SCRIPT_LINES.slice(1)) {
        await sleep(line.delay + 90);
        const span = document.createElement('span');
        span.className = line.cls ?? '';
        span.textContent = line.text;
        cursor?.before(document.createTextNode('\n'));
        cursor?.before(span);
      }
    }

    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          play();
          io.disconnect();
        }
      },
      { threshold: 0.35 }
    );
    io.observe(term);
  }

  document.addEventListener('astro:page-load', initTerminal);
</script>
