---
import Icon from './Icon.astro';
import { projects, tabs } from '../data/profile';

interface Props {
  // true cuando se renderiza como sección propia (no embebida junto a ProfileCard)
  standalone?: boolean;
}

const { standalone = false } = Astro.props;
---

<section id="proyectos" class:list={['proj', { container: standalone, 'proj--standalone': standalone }]}>
  <div class="proj__bar" data-reveal>
    <div>
      <span class="kicker">GitHub</span>
      <h2>Proyectos</h2>
      <p class="proj__sub">Repos públicos reales — el código y el detalle completo están en cada uno.</p>
    </div>
    <div class="proj__tabs" role="tablist" aria-label="Filtrar proyectos">
      {
        tabs.map((tab, i) => (
          <button
            class:list={['proj__tab', { active: i === 0 }]}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-filter={tab.id}
          >
            {tab.label}
          </button>
        ))
      }
    </div>
  </div>

  <div class="proj__grid" id="proj-grid">
    {
      projects.map((p, i) => (
        <a
          class="proj-card card"
          id={p.id}
          href={p.repo}
          target="_blank"
          rel="noopener"
          data-category={p.category}
          data-tilt
          data-reveal
          style={`--d: ${(i % 2) * 0.08}s`}
        >
          <header class="proj-card__head">
            <span class="proj-card__icon" style={`--hue: ${p.iconHue}`}>
              <Icon name={p.icon} size={22} />
            </span>
            <div class="proj-card__titles">
              <h3>{p.title}</h3>
              <p>{p.org}</p>
            </div>
            <span class="proj-card__external">
              <Icon name="external" size={16} />
            </span>
          </header>

          <p class="proj-card__desc">{p.summary}</p>

          <div class="proj-card__chips">
            <span class="chip chip--outline">{p.level}</span>
            {p.tags.map((t) => (
              <span class="chip chip--outline">{t}</span>
            ))}
          </div>

          <footer class="proj-card__actions">
            <span class="proj-card__link">
              <Icon name="github" size={15} /> Ver en GitHub
            </span>
          </footer>
        </a>
      ))
    }
  </div>
</section>

<style>
  .proj--standalone {
    margin-top: 90px;
  }

  .proj__bar {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 22px;
    flex-wrap: wrap;
  }

  .proj__sub {
    margin-top: 6px;
    font-size: 13.5px;
    color: var(--text-3);
  }

  .proj__tabs {
    display: flex;
    gap: 6px;
    padding: 5px;
    border-radius: var(--r-full);
    background: var(--panel);
    border: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
    flex-shrink: 0;
  }

  .proj__tabs::-webkit-scrollbar {
    display: none;
  }

  .proj__tab {
    padding: 8px 18px;
    border-radius: var(--r-full);
    font-size: 13.5px;
    font-weight: 550;
    color: var(--text-2);
    white-space: nowrap;
    transition: color 0.2s, background 0.2s;
  }

  .proj__tab:hover {
    color: var(--text);
  }

  .proj__tab.active {
    background: var(--card-hover);
    border: 1px solid var(--border-strong);
    color: var(--text);
    padding: 7px 17px;
  }

  .proj__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 1080px) {
    .proj__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .proj-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 22px;
    border-radius: var(--r-lg);
    scroll-margin-top: 90px;
    color: inherit;
    text-decoration: none;
  }

  .proj-card.hide {
    display: none;
  }

  .proj-card__head {
    display: flex;
    align-items: center;
    gap: 13px;
  }

  .proj-card__icon {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    background: #fff;
    color: hsl(var(--hue) 75% 45%);
    box-shadow: 0 6px 16px -6px rgba(0, 0, 0, 0.5);
  }

  .proj-card__titles {
    min-width: 0;
  }

  .proj-card__titles h3 {
    font-size: 16.5px;
    font-weight: 650;
  }

  .proj-card__titles p {
    margin-top: 2px;
    font-size: 12.5px;
    color: var(--text-3);
  }

  .proj-card__external {
    margin-left: auto;
    color: var(--text-3);
    transition: color 0.2s, transform 0.2s;
  }

  .proj-card:hover .proj-card__external {
    color: var(--accent-hover);
    transform: translate(2px, -2px);
  }

  .proj-card__desc {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-2);
  }

  .proj-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .proj-card__actions {
    margin-top: auto;
    padding-top: 4px;
  }

  .proj-card__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--accent-hover);
  }

  .proj-card:hover .proj-card__link {
    color: var(--cyan);
  }
</style>

<script>
  function initProjects() {
    const grid = document.getElementById('proj-grid');
    if (!grid || grid.dataset.init) return;
    grid.dataset.init = '1';

    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.proj-card'));
    const tabButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.proj__tab'));

    tabButtons.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabButtons.forEach((t) => {
          t.classList.toggle('active', t === tab);
          t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
        });
        const filter = tab.dataset.filter;
        let visible = 0;
        cards.forEach((card) => {
          const show = filter === 'all' || card.dataset.category === filter;
          card.classList.toggle('hide', !show);
          if (show) {
            visible++;
            card.animate(
              [
                { opacity: 0, transform: 'translateY(14px)' },
                { opacity: 1, transform: 'none' },
              ],
              { duration: 350, easing: 'cubic-bezier(.2,.6,.2,1)', delay: visible * 40, fill: 'backwards' }
            );
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initProjects);
</script>
