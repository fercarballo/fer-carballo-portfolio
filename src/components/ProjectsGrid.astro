---
import Icon from './Icon.astro';
import { projects, tabs, profile } from '../data/profile';

interface Props {
  // true cuando se renderiza como sección propia (no embebida junto a ProfileCard)
  standalone?: boolean;
}

const { standalone = false } = Astro.props;
---

<section id="proyectos" class:list={['proj', { container: standalone, 'proj--standalone': standalone }]}>
  <div class="proj__bar" data-reveal>
    <div class="proj__tabs" role="tablist" aria-label="Filtrar proyectos">
      {
        tabs.map((tab, i) => (
          <button
            class:list={['proj__tab', { active: i === 0 }]}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-filter={tab.id}
          >
            {tab.label}
          </button>
        ))
      }
    </div>
    <div class="proj__meta">
      <span class="proj__count" id="proj-count">{projects.length} proyectos</span>
      <span class="proj__sort"><Icon name="filter" size={15} /></span>
    </div>
  </div>

  <div class="proj__grid" id="proj-grid">
    {
      projects.map((p, i) => (
        <article
          class="proj-card card"
          id={p.id}
          data-category={p.category}
          data-tilt
          data-reveal
          style={`--d: ${(i % 2) * 0.08}s`}
        >
          <header class="proj-card__head">
            <span class="proj-card__icon" style={`--hue: ${p.iconHue}`}>
              <Icon name={p.icon} size={22} />
            </span>
            <div class="proj-card__titles">
              <h3>{p.title}</h3>
              <p>{p.org}</p>
            </div>
            <span class="proj-card__dots">
              <Icon name="dots" size={18} />
            </span>
          </header>

          <p class="proj-card__desc">
            {p.summary}
            <button class="proj-card__more" data-open={`modal-${p.id}`}>más</button>
          </p>

          <div class="proj-card__chips">
            <span class="chip chip--outline">{p.level}</span>
            {p.tags.map((t) => (
              <span class="chip chip--outline">{t}</span>
            ))}
          </div>

          <footer class="proj-card__actions">
            <button class="btn btn--primary" data-open={`modal-${p.id}`}>
              Ver detalles
            </button>
            <a class="btn btn--light" href={p.repo ?? profile.links.github} target="_blank" rel="noopener">
              <Icon name="github" size={15} /> Código
            </a>
          </footer>

          <dialog class="proj-modal" id={`modal-${p.id}`} aria-label={p.title}>
            <div class="proj-modal__box">
              <header class="proj-modal__head">
                <span class="proj-card__icon" style={`--hue: ${p.iconHue}`}>
                  <Icon name={p.icon} size={22} />
                </span>
                <div class="proj-card__titles">
                  <h3>{p.title}</h3>
                  <p>{p.org}</p>
                </div>
                <button class="proj-modal__close" data-close aria-label="Cerrar">
                  <Icon name="close" size={17} />
                </button>
              </header>
              <ul class="proj-modal__list">
                {p.details.map((d) => (
                  <li>
                    <Icon name="check" size={15} />
                    <span>{d}</span>
                  </li>
                ))}
              </ul>
              <div class="proj-card__chips">
                <span class="chip">{p.level}</span>
                {p.tags.map((t) => (
                  <span class="chip">{t}</span>
                ))}
              </div>
              <footer class="proj-modal__foot">
                <a class="btn btn--primary" href={p.repo ?? profile.links.github} target="_blank" rel="noopener">
                  <Icon name="github" size={15} /> Ver código
                </a>
                <button class="btn btn--ghost" data-close>Cerrar</button>
              </footer>
            </div>
          </dialog>
        </article>
      ))
    }
  </div>
</section>

<style>
  .proj--standalone {
    margin-top: 90px;
  }

  .proj__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 22px;
  }

  .proj__tabs {
    display: flex;
    gap: 6px;
    padding: 5px;
    border-radius: var(--r-full);
    background: var(--panel);
    border: 1px solid var(--border);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .proj__tabs::-webkit-scrollbar {
    display: none;
  }

  .proj__tab {
    padding: 8px 18px;
    border-radius: var(--r-full);
    font-size: 13.5px;
    font-weight: 550;
    color: var(--text-2);
    white-space: nowrap;
    transition: color 0.2s, background 0.2s;
  }

  .proj__tab:hover {
    color: var(--text);
  }

  .proj__tab.active {
    background: var(--card-hover);
    border: 1px solid var(--border-strong);
    color: var(--text);
    padding: 7px 17px;
  }

  .proj__meta {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .proj__count {
    font-size: 12.5px;
    color: var(--text-3);
    white-space: nowrap;
  }

  .proj__sort {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--panel);
    border: 1px solid var(--border);
    color: var(--text-2);
  }

  .proj__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  @media (max-width: 1080px) {
    .proj__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  .proj__tabs {
    min-width: 0;
  }

  .proj-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 22px;
    border-radius: var(--r-lg);
    scroll-margin-top: 90px;
  }

  .proj-card.hide {
    display: none;
  }

  .proj-card__head {
    display: flex;
    align-items: center;
    gap: 13px;
  }

  .proj-card__icon {
    display: grid;
    place-items: center;
    flex-shrink: 0;
    width: 46px;
    height: 46px;
    border-radius: 14px;
    background: #fff;
    color: hsl(var(--hue) 75% 45%);
    box-shadow: 0 6px 16px -6px rgba(0, 0, 0, 0.5);
  }

  .proj-card__titles {
    min-width: 0;
  }

  .proj-card__titles h3 {
    font-size: 16.5px;
    font-weight: 650;
  }

  .proj-card__titles p {
    margin-top: 2px;
    font-size: 12.5px;
    color: var(--text-3);
  }

  .proj-card__dots {
    margin-left: auto;
    color: var(--text-3);
  }

  .proj-card__desc {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-2);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .proj-card__more {
    display: inline;
    padding: 0;
    margin-left: 4px;
    color: var(--green);
    font-size: 13px;
    font-weight: 550;
  }

  .proj-card__more:hover {
    text-decoration: underline;
  }

  .proj-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .proj-card__actions {
    display: flex;
    gap: 10px;
    margin-top: auto;
    padding-top: 4px;
  }

  /* ── Modal de detalles ── */
  .proj-modal {
    margin: auto;
    padding: 0;
    width: min(560px, calc(100vw - 32px));
    background: transparent;
    border: 0;
    outline: none;
  }

  .proj-modal::backdrop {
    background: rgba(2, 2, 6, 0.7);
    backdrop-filter: blur(6px);
  }

  .proj-modal__box {
    background: #16161a;
    border: 1px solid var(--border-strong);
    border-radius: 22px;
    padding: 24px;
    display: grid;
    gap: 18px;
    box-shadow: 0 40px 120px -20px rgba(0, 0, 0, 0.85);
  }

  .proj-modal[open] .proj-modal__box {
    animation: modal-in 0.3s cubic-bezier(0.2, 0.9, 0.3, 1.2);
  }

  @keyframes modal-in {
    from {
      opacity: 0;
      transform: translateY(16px) scale(0.97);
    }
  }

  .proj-modal__head {
    display: flex;
    align-items: center;
    gap: 13px;
  }

  .proj-modal__close {
    margin-left: auto;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--chip);
    border: 1px solid var(--border);
    color: var(--text-2);
    flex-shrink: 0;
  }

  .proj-modal__close:hover {
    color: var(--text);
  }

  .proj-modal__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 11px;
  }

  .proj-modal__list li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 13.5px;
    line-height: 1.55;
    color: var(--text-2);
  }

  .proj-modal__list li :global(svg) {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--green);
  }

  .proj-modal__foot {
    display: flex;
    gap: 10px;
    padding-top: 4px;
  }
</style>

<script>
  function initProjects() {
    const grid = document.getElementById('proj-grid');
    if (!grid || grid.dataset.init) return;
    grid.dataset.init = '1';

    const cards = Array.from(grid.querySelectorAll<HTMLElement>('.proj-card'));
    const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.proj__tab'));
    const count = document.getElementById('proj-count');

    // Filtro por categoría con micro-animación de entrada
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((t) => {
          t.classList.toggle('active', t === tab);
          t.setAttribute('aria-selected', t === tab ? 'true' : 'false');
        });
        const filter = tab.dataset.filter;
        let visible = 0;
        cards.forEach((card) => {
          const show = filter === 'all' || card.dataset.category === filter;
          card.classList.toggle('hide', !show);
          if (show) {
            visible++;
            card.animate(
              [
                { opacity: 0, transform: 'translateY(14px)' },
                { opacity: 1, transform: 'none' },
              ],
              { duration: 350, easing: 'cubic-bezier(.2,.6,.2,1)', delay: visible * 40, fill: 'backwards' }
            );
          }
        });
        if (count) count.textContent = `${visible} proyecto${visible === 1 ? '' : 's'}`;
      });
    });

    // Modales de detalle
    document.querySelectorAll<HTMLElement>('[data-open]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const dialog = document.getElementById(btn.dataset.open!) as HTMLDialogElement | null;
        dialog?.showModal();
      });
    });

    document.querySelectorAll<HTMLDialogElement>('.proj-modal').forEach((dialog) => {
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });
      dialog.querySelectorAll('[data-close]').forEach((btn) => {
        btn.addEventListener('click', () => dialog.close());
      });
    });
  }

  document.addEventListener('astro:page-load', initProjects);
</script>
