---
import Icon from './Icon.astro';
import { profile } from '../data/profile';
---

<header class="nav-wrap">
  <nav class="container nav" aria-label="Principal">
    <div class="nav__left">
      <a href="/" class="logo" aria-label="FC — Inicio">
        <span class="logo__mark">FC</span>
      </a>
      <div class="nav__links">
        <a href="/#proyectos">Proyectos</a>
        <a href="/#experiencia">Experiencia</a>
        <a href="/blog">Blog</a>
        <a href="/#contacto">Contacto</a>
      </div>
    </div>

    <button class="search" data-open-palette aria-keyshortcuts="Meta+K Control+K">
      <Icon name="search" size={15} />
      <span class="search__label">Buscar en el sitio…</span>
      <kbd aria-hidden="true">⌘K</kbd>
    </button>

    <div class="nav__right">
      <a class="icon-btn" href={profile.links.github} target="_blank" rel="noopener" aria-label="GitHub">
        <Icon name="github" size={17} />
      </a>
      <a class="icon-btn" href={profile.links.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
        <Icon name="linkedin" size={17} />
      </a>
      <a class="avatar" href="/#top" aria-label="FC — Perfil">FC</a>
    </div>
  </nav>
</header>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: rgba(8, 8, 10, 0.72);
    border-bottom: 1px solid var(--border);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    height: 66px;
  }

  .nav__left {
    display: flex;
    align-items: center;
    gap: 22px;
    min-width: 0;
  }

  .logo__mark {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 12px;
    background: linear-gradient(135deg, #5ec6ff, #22a05a 70%);
    color: #fff;
    font-weight: 800;
    font-size: 13px;
    letter-spacing: -0.03em;
    box-shadow: 0 6px 18px -6px rgba(34, 160, 90, 0.6);
  }

  .nav__links {
    display: flex;
    gap: 4px;
  }

  .nav__links a {
    padding: 7px 12px;
    border-radius: var(--r-full);
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text-2);
    transition: color 0.2s, background 0.2s;
  }

  .nav__links a:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.05);
  }

  .search {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 0 1 300px;
    padding: 9px 14px;
    border-radius: var(--r-full);
    background: var(--panel);
    border: 1px solid var(--border);
    color: var(--text-3);
    font-size: 13px;
    transition: border-color 0.2s, background 0.2s;
  }

  .search:hover {
    border-color: var(--border-strong);
    background: var(--card);
  }

  .search__label {
    flex: 1;
    text-align: left;
  }

  .search kbd {
    font-family: var(--mono);
    font-size: 10.5px;
    padding: 2px 7px;
    border-radius: 6px;
    background: var(--chip);
    border: 1px solid var(--border);
    color: var(--text-2); /* 4.5:1 sobre --chip; --text-3 no llegaba */
  }

  .nav__right {
    display: flex;
    align-items: center;
    gap: 9px;
  }

  .icon-btn {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--panel);
    border: 1px solid var(--border);
    color: var(--text-2);
    transition: color 0.2s, border-color 0.2s, transform 0.15s;
  }

  .icon-btn:hover {
    color: var(--text);
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }

  .avatar {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: linear-gradient(140deg, #14532d, #22a05a);
    border: 1px solid var(--border-strong);
    font-size: 12px;
    font-weight: 700;
    color: #dbe6ff;
  }

  @media (max-width: 880px) {
    .nav__links {
      display: none;
    }

    .search {
      flex: 1;
    }

    .search kbd {
      display: none;
    }
  }
</style>
