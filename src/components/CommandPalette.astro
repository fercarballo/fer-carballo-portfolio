---
import Icon from './Icon.astro';
import { getCollection } from 'astro:content';
import { projects } from '../data/profile';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

type Item = { label: string; hint: string; href: string; group: string };

const items: Item[] = [
  { label: 'Inicio', hint: 'Perfil y proyectos', href: '/#top', group: 'Secciones' },
  { label: 'Proyectos', hint: 'QA · DevOps · Dev', href: '/#proyectos', group: 'Secciones' },
  { label: 'Cómo trabajo', hint: 'Pipeline de calidad', href: '/#proceso', group: 'Secciones' },
  { label: 'Experiencia', hint: 'Trayectoria profesional', href: '/#experiencia', group: 'Secciones' },
  { label: 'Certificaciones', hint: 'Formación y cursos', href: '/#certificaciones', group: 'Secciones' },
  { label: 'Blog', hint: 'Artículos sobre QA y DevOps', href: '/blog', group: 'Secciones' },
  { label: 'Contacto', hint: 'Hablemos', href: '/#contacto', group: 'Secciones' },
  { label: 'Descargar CV', hint: 'PDF actualizado', href: '/cv/Fernando-Carballo-CV.pdf', group: 'Acciones' },
  ...projects.map((p) => ({ label: p.title, hint: p.org, href: `/#${p.id}`, group: 'Proyectos' })),
  ...posts.map((p) => ({ label: p.data.title, hint: 'Artículo del blog', href: `/blog/${p.id}`, group: 'Blog' })),
];
---

<dialog id="palette" aria-label="Buscador del sitio" transition:persist="palette">
  <div class="palette__box">
    <div class="palette__input-row">
      <Icon name="search" size={16} />
      <input id="palette-input" type="text" placeholder="Buscar proyectos, secciones, artículos…" autocomplete="off" spellcheck="false" />
      <kbd>esc</kbd>
    </div>
    <ul id="palette-list" class="palette__list"></ul>
    <div class="palette__foot">
      <span><kbd>↑↓</kbd> navegar</span>
      <span><kbd>↵</kbd> abrir</span>
    </div>
  </div>
</dialog>

<script is:inline define:vars={{ items }} id="palette-data">
  window.__paletteItems = items;
</script>

<style>
  #palette {
    margin: 12vh auto 0;
    padding: 0;
    width: min(600px, calc(100vw - 32px));
    background: transparent;
    border: 0;
    outline: none;
  }

  #palette::backdrop {
    background: rgba(2, 2, 6, 0.65);
    backdrop-filter: blur(6px);
  }

  .palette__box {
    background: #141418;
    border: 1px solid var(--border-strong);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 40px 100px -20px rgba(0, 0, 0, 0.8);
    color: var(--text);
    font-family: var(--font);
  }

  .palette__input-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 15px 18px;
    border-bottom: 1px solid var(--border);
    color: var(--text-3);
  }

  #palette-input {
    flex: 1;
    background: none;
    border: 0;
    outline: none;
    color: var(--text);
    font-size: 15px;
    font-family: inherit;
  }

  #palette-input::placeholder {
    color: var(--text-3);
  }

  kbd {
    font-family: var(--mono);
    font-size: 10.5px;
    padding: 2px 7px;
    border-radius: 6px;
    background: var(--chip);
    border: 1px solid var(--border);
    color: var(--text-3);
  }

  .palette__list {
    list-style: none;
    margin: 0;
    padding: 8px;
    max-height: 320px;
    overflow-y: auto;
  }

  .palette__list :global(.group-label) {
    padding: 10px 12px 4px;
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }

  .palette__list :global(a) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 14px;
    color: var(--text);
  }

  .palette__list :global(a .hint) {
    font-size: 12px;
    color: var(--text-3);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .palette__list :global(li.active a),
  .palette__list :global(a:hover) {
    background: var(--accent-soft);
  }

  .palette__list :global(.empty) {
    padding: 24px 12px;
    text-align: center;
    color: var(--text-3);
    font-size: 13.5px;
  }

  .palette__foot {
    display: flex;
    gap: 18px;
    padding: 10px 18px;
    border-top: 1px solid var(--border);
    font-size: 11.5px;
    color: var(--text-3);
  }
</style>

<script>
  function initPalette() {
    const dialog = document.getElementById('palette') as HTMLDialogElement | null;
    const input = document.getElementById('palette-input') as HTMLInputElement | null;
    const list = document.getElementById('palette-list');
    if (!dialog || !input || !list || dialog.dataset.init) return;
    dialog.dataset.init = '1';

    type Item = { label: string; hint: string; href: string; group: string };
    const items: Item[] = (window as any).__paletteItems ?? [];
    let active = 0;
    let visible: Item[] = [];

    function render(query: string) {
      const q = query.trim().toLowerCase();
      visible = q
        ? items.filter((i) => (i.label + ' ' + i.hint + ' ' + i.group).toLowerCase().includes(q))
        : items;
      active = 0;

      if (!visible.length) {
        list!.innerHTML = '<li class="empty">Sin resultados — probá con otra palabra</li>';
        return;
      }

      let html = '';
      let lastGroup = '';
      visible.forEach((item, i) => {
        if (item.group !== lastGroup) {
          html += `<li class="group-label">${item.group}</li>`;
          lastGroup = item.group;
        }
        html += `<li data-i="${i}" class="${i === 0 ? 'active' : ''}"><a href="${item.href}"><span>${item.label}</span><span class="hint">${item.hint}</span></a></li>`;
      });
      list!.innerHTML = html;
    }

    function setActive(i: number) {
      active = Math.max(0, Math.min(i, visible.length - 1));
      list!.querySelectorAll('li[data-i]').forEach((li) => {
        const on = Number((li as HTMLElement).dataset.i) === active;
        li.classList.toggle('active', on);
        if (on) li.scrollIntoView({ block: 'nearest' });
      });
    }

    function open() {
      dialog!.showModal();
      input!.value = '';
      render('');
      input!.focus();
    }

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        dialog!.open ? dialog!.close() : open();
      }
      if (!dialog!.open) return;
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(active + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(active - 1);
      } else if (e.key === 'Enter') {
        const target = visible[active];
        if (target) {
          dialog!.close();
          window.location.href = target.href;
        }
      }
    });

    input.addEventListener('input', () => render(input!.value));

    list.addEventListener('click', () => dialog!.close());

    // Cerrar al clickear el backdrop
    dialog.addEventListener('click', (e) => {
      if (e.target === dialog) dialog!.close();
    });

    // Delegado en document: los botones del nav se recrean en cada view transition
    document.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('[data-open-palette]')) open();
    });
  }

  document.addEventListener('astro:page-load', initPalette);
</script>
