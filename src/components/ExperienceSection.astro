---
import Icon from './Icon.astro';
import { experience } from '../data/profile';

interface Props {
  // true cuando se renderiza dentro del layout de dos columnas (junto a ProfileCard)
  embedded?: boolean;
}

const { embedded = false } = Astro.props;
---

<section id="experiencia" class:list={['exp', { container: !embedded, 'exp--embedded': embedded }]}>
  <div class="section-head" data-reveal>
    <div>
      <span class="kicker">Trayectoria</span>
      <h2>Experiencia profesional</h2>
    </div>
  </div>

  <div class="exp__timeline">
    {
      experience.map((job, i) => (
        <article class="exp__item" data-reveal style={`--d: ${i * 0.06}s`}>
          <div class="exp__rail">
            <span class="exp__logo" style={`--hue: ${job.badgeHue}`}>{job.badge}</span>
            {i < experience.length - 1 && <span class="exp__line" />}
          </div>
          <div class="exp__content card" data-tilt>
            <header class="exp__head">
              <div>
                <h3>{job.role}</h3>
                <p class="exp__company">{job.company}</p>
              </div>
              <div class="exp__dates">
                <span class="chip chip--outline">{job.type}</span>
                <span class="exp__range">
                  {job.start} – {job.end} · {job.duration}
                </span>
              </div>
            </header>
            <ul class="exp__bullets">
              {job.bullets.map((b) => (
                <li>
                  <Icon name="check" size={14} />
                  <span>{b}</span>
                </li>
              ))}
            </ul>
            {job.tools && (
              <div class="exp__tools">
                {job.tools.map((t) => <span class="chip chip--outline">{t}</span>)}
              </div>
            )}
          </div>
        </article>
      ))
    }
  </div>
</section>

<style>
  .exp {
    margin-top: 90px;
  }

  .exp--embedded {
    margin-top: 0;
  }

  .exp__timeline {
    display: grid;
    gap: 20px;
  }

  .exp__item {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 18px;
  }

  .exp__rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
  }

  .exp__logo {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 14px;
    flex-shrink: 0;
    font-size: 14px;
    font-weight: 800;
    color: #fff;
    background: linear-gradient(140deg, hsl(var(--hue) 65% 20%), hsl(var(--hue) 80% 45%));
    border: 1px solid rgba(255, 255, 255, 0.09);
    box-shadow: 0 8px 20px -8px hsl(var(--hue) 80% 45% / 0.5);
  }

  .exp__line {
    flex: 1;
    width: 2px;
    background: linear-gradient(180deg, var(--border-strong), transparent);
    border-radius: 2px;
  }

  .exp__content {
    padding: 22px 24px;
    border-radius: var(--r-lg);
  }

  .exp__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 14px;
  }

  .exp__head h3 {
    font-size: 16.5px;
    font-weight: 650;
  }

  .exp__company {
    margin-top: 3px;
    font-size: 13px;
    color: var(--accent-hover);
    font-weight: 550;
  }

  .exp__dates {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .exp__range {
    font-size: 12.5px;
    color: var(--text-3);
    white-space: nowrap;
  }

  .exp__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 9px;
  }

  .exp__bullets li {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-2);
  }

  .exp__bullets li :global(svg) {
    flex-shrink: 0;
    margin-top: 4px;
    color: var(--green);
  }

  .exp__tools {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 640px) {
    .exp__item {
      grid-template-columns: 1fr;
    }

    .exp__rail {
      flex-direction: row;
    }

    .exp__line {
      height: 2px;
      width: auto;
      flex: 1;
      background: linear-gradient(90deg, var(--border-strong), transparent);
      align-self: center;
    }
  }
</style>
