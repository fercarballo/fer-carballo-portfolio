---
import { existsSync } from 'node:fs';
import Icon from './Icon.astro';
import { profile } from '../data/profile';

// Usa la foto real si está en public/avatar/fer.jpg (optimizada al importarla);
// si no, cae en las iniciales "FC" con el degradado de la paleta.
const hasPhoto = existsSync(new URL('../../public/avatar/fer.jpg', import.meta.url));
---

<aside class="pcard card" data-reveal>
  <div class="pcard__avatar-wrap">
    {
      hasPhoto ? (
        <img
          class="pcard__avatar pcard__avatar--photo"
          src="/avatar/fer.jpg"
          alt={profile.name}
          width="128"
          height="128"
          fetchpriority="high"
          decoding="async"
        />
      ) : (
        <div class="pcard__avatar" aria-hidden="true">
          <span>FC</span>
        </div>
      )
    }
    <span class="pcard__badge" title="Disponible">
      <Icon name="check" size={12} />
    </span>
  </div>

  <h1 class="pcard__name">{profile.name}</h1>
  <p class="pcard__role" id="rotating-role">
    <span class="rot" data-roles={JSON.stringify(profile.roles)}>{profile.roles[1]}</span>
  </p>
  <p class="pcard__loc"><Icon name="pin" size={13} /> {profile.location}</p>

  <a class="pcard__cta" href={profile.cvUrl} download>
    <span class="pcard__cta-icon"><Icon name="download" size={15} /></span>
    <span>Descargar mi CV</span>
    <Icon name="arrow-right" size={16} class="pcard__cta-arrow" />
  </a>

  <section class="pcard__section">
    <h2>Sobre mí</h2>
    {profile.about.map((p) => <p class="pcard__about">{p}</p>)}
  </section>

  <section class="pcard__section">
    <h2>Resultados</h2>
    <div class="pcard__stats">
      {
        profile.highlights.map((h) => (
          <div class="pcard__stat">
            <strong>{h.value}</strong>
            <span>{h.label}</span>
          </div>
        ))
      }
    </div>
  </section>

  <section class="pcard__section pcard__section--last">
    <h2>Links</h2>
    <div class="pcard__links">
      <a href={profile.links.github} target="_blank" rel="noopener" aria-label="GitHub"><Icon name="github" size={16} /></a>
      <a href={profile.links.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"><Icon name="linkedin" size={16} /></a>
      <a href={`mailto:${profile.email}`} aria-label="Email"><Icon name="mail" size={16} /></a>
    </div>
  </section>
</aside>

<style>
  .pcard {
    position: relative;
    padding: 0 26px 10px;
    border-radius: var(--r-xl);
    background: #121216;
  }

  .pcard__avatar-wrap {
    position: relative;
    width: 128px;
    margin-top: -58px; /* pisa el banner */
  }

  .pcard__avatar {
    display: grid;
    place-items: center;
    width: 128px;
    height: 128px;
    border-radius: 50%;
    background: linear-gradient(140deg, #14532d, #22a05a 60%, #5ec6ff);
    border: 4px solid #121216;
    box-shadow: 0 12px 34px -8px rgba(34, 160, 90, 0.55);
    font-size: 34px;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #eaf1ff;
  }

  /* Foto real: mismo círculo, object-fit para no deformar */
  .pcard__avatar--photo {
    object-fit: cover;
    object-position: center 22%;
    background: #14532d;
  }

  .pcard__badge {
    position: absolute;
    right: 6px;
    bottom: 6px;
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid #121216;
    color: #fff;
  }

  .pcard__name {
    margin-top: 16px;
    font-size: 25px;
    font-weight: 700;
  }

  .pcard__role {
    margin-top: 4px;
    font-size: 14px;
    color: var(--accent-hover);
    font-weight: 550;
    min-height: 22px;
  }

  .rot {
    display: inline-block;
  }

  .rot.swap {
    animation: rot-swap 0.45s ease;
  }

  @keyframes rot-swap {
    0% {
      opacity: 0;
      transform: translateY(8px);
      filter: blur(4px);
    }
    100% {
      opacity: 1;
      transform: none;
      filter: none;
    }
  }

  .pcard__loc {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 6px;
    font-size: 12.5px;
    color: var(--text-3);
  }

  .pcard__cta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 20px;
    padding: 11px 16px;
    border-radius: var(--r-full);
    border: 1px solid var(--border-strong);
    background: rgba(255, 255, 255, 0.03);
    font-size: 13.5px;
    font-weight: 600;
    transition: border-color 0.2s, background 0.2s;
  }

  .pcard__cta:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
  }

  .pcard__cta-icon {
    display: grid;
    place-items: center;
    color: var(--accent-hover);
  }

  .pcard__cta :global(.pcard__cta-arrow) {
    margin-left: auto;
    transition: transform 0.25s ease;
  }

  .pcard__cta:hover :global(.pcard__cta-arrow) {
    transform: translateX(4px);
  }

  .pcard__section {
    margin-top: 24px;
    padding-top: 22px;
    border-top: 1px solid var(--border);
  }

  .pcard__section--last {
    padding-bottom: 16px;
  }

  .pcard__section h2 {
    font-size: 14.5px;
    font-weight: 650;
    margin-bottom: 13px;
  }

  .pcard__about {
    font-size: 13px;
    line-height: 1.65;
    color: var(--text-2);
  }

  .pcard__about + .pcard__about {
    margin-top: 10px;
  }

  .pcard__stats {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pcard__stat {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 10px 14px;
    border-radius: var(--r-lg);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
  }

  .pcard__stat strong {
    font-size: 16px;
    font-weight: 750;
    color: var(--accent-hover);
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .pcard__stat span {
    font-size: 12px;
    line-height: 1.5;
    color: var(--text-2);
  }

  .pcard__links {
    display: flex;
    gap: 10px;
  }

  .pcard__links a {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: var(--chip);
    border: 1px solid var(--border);
    color: var(--text-2);
    transition: color 0.2s, border-color 0.2s, transform 0.15s;
  }

  .pcard__links a:hover {
    color: var(--text);
    border-color: var(--accent);
    transform: translateY(-2px);
  }
</style>

<script>
  // Rotación de roles: QA Manual → QA Automation → SDET → DevOps → Developer
  function initRoleRotation() {
    const el = document.querySelector<HTMLElement>('#rotating-role .rot');
    if (!el || el.dataset.init) return;
    el.dataset.init = '1';
    if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const roles: string[] = JSON.parse(el.dataset.roles || '[]');
    if (roles.length < 2) return;
    let i = roles.indexOf(el.textContent?.trim() || '') ;

    setInterval(() => {
      i = (i + 1) % roles.length;
      el.classList.remove('swap');
      // reflow para reiniciar la animación
      void el.offsetWidth;
      el.textContent = roles[i];
      el.classList.add('swap');
    }, 2600);
  }

  document.addEventListener('astro:page-load', initRoleRotation);
</script>
