---
import Icon from './Icon.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  index?: number;
}

const { post, index = 0 } = Astro.props;

const date = post.data.pubDate.toLocaleDateString('es-AR', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
});

// Estimación de lectura: ~200 palabras/min
const words = post.body?.split(/\s+/).length ?? 0;
const minutes = Math.max(1, Math.round(words / 200));
---

<article class="blog-card card" data-tilt data-reveal style={`--d: ${(index % 3) * 0.07}s`}>
  <header class="blog-card__head">
    <span class="blog-card__icon" style={`--hue: ${post.data.iconHue}`}>
      <Icon name={post.data.icon} size={21} />
    </span>
    <div class="blog-card__meta">
      <time datetime={post.data.pubDate.toISOString()}>{date}</time>
      <span>·</span>
      <span><Icon name="clock" size={12} /> {minutes} min</span>
    </div>
  </header>

  <div class="blog-card__badges">
    <span class={`badge ${post.data.type === 'pilar' ? 'badge--pilar' : 'badge--sat'}`}>
      {post.data.type === 'pilar' ? 'Pilar' : 'Satélite'}
    </span>
    <a class="badge badge--cluster" href={`/blog/coleccion/${post.data.cluster}/`}>
      {post.data.clusterTitle}
    </a>
  </div>

  <h3 class="blog-card__title">
    <a href={`/blog/${post.id}/`}>{post.data.title}</a>
  </h3>

  <p class="blog-card__desc">{post.data.description}</p>

  <div class="blog-card__chips">
    {post.data.tags.slice(0, 3).map((t) => <span class="chip chip--outline">{t}</span>)}
  </div>

  <footer class="blog-card__foot">
    <a class="btn btn--primary" href={`/blog/${post.id}/`}>Leer artículo</a>
  </footer>
</article>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 13px;
    padding: 22px;
    border-radius: var(--r-lg);
  }

  .blog-card__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .blog-card__icon {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 13px;
    background: #fff;
    color: hsl(var(--hue) 75% 45%);
    box-shadow: 0 6px 16px -6px rgba(0, 0, 0, 0.5);
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 7px;
    font-size: 12px;
    color: var(--text-3);
  }

  .blog-card__meta span {
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .blog-card__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .blog-card__badges .badge--cluster {
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    display: inline-block;
  }

  .blog-card__title {
    font-size: 17px;
    font-weight: 650;
    line-height: 1.35;
  }

  .blog-card__title a:hover {
    color: var(--accent-hover);
  }

  .blog-card__desc {
    font-size: 13.5px;
    line-height: 1.6;
    color: var(--text-2);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .blog-card__foot {
    margin-top: auto;
    padding-top: 4px;
  }
</style>
