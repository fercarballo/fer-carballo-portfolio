---
import '@fontsource-variable/inter';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import CommandPalette from '../components/CommandPalette.astro';
import { profile } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  image?: string;
  publishedTime?: string;
  tags?: string[];
}

const {
  title = `${profile.name} — QA Engineer · QA Manual & Automation · SDET`,
  description = 'Portfolio de Fernando Carballo, QA Engineer con 4+ años en telecomunicaciones. Testing manual y automatizado con Cypress, Playwright y Postman (API), SDET, SQL y CI/CD. Calidad de extremo a extremo con criterio de desarrollo.',
  ogType = 'website',
  image = '/og.jpg',
  publishedTime,
  tags = [],
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);

// ── Datos estructurados (JSON-LD) para aparecer en búsquedas reales ──
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  url: Astro.site?.href,
  image: new URL('/avatar/fer.jpg', Astro.site).href,
  jobTitle: 'QA Engineer',
  email: `mailto:${profile.email}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Buenos Aires',
    addressCountry: 'AR',
  },
  worksFor: { '@type': 'Organization', name: 'Personal (Telecom Argentina)' },
  knowsAbout: [
    'Quality Assurance', 'Software Testing', 'Test Automation', 'Cypress',
    'Playwright', 'Postman', 'API Testing', 'SDET', 'JavaScript', 'SQL', 'CI/CD',
  ],
  sameAs: [profile.links.github, profile.links.linkedin],
};

const articleSchema = ogType === 'article'
  ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: title,
      description,
      image: ogImage.href,
      datePublished: publishedTime,
      author: { '@type': 'Person', name: profile.name, url: Astro.site?.href },
      publisher: { '@type': 'Person', name: profile.name },
      mainEntityOfPage: canonical.href,
      keywords: tags.join(', '),
    }
  : null;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={profile.name} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Blog de Fernando Carballo" href="/rss.xml" />
    <meta name="theme-color" content="#0a0e0b" />
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={`${profile.name} — Portfolio`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${profile.name} — QA Engineer`} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && <meta property="article:author" content={profile.name} />}
    {tags.map((t) => <meta property="article:tag" content={t} />)}
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
    <ClientRouter />
  </head>
  <body>
    <canvas id="starfield" aria-hidden="true"></canvas>
    <Nav />
    <slot />
    <Footer />
    <CommandPalette />

    <style>
      #starfield {
        position: fixed;
        inset: 0;
        z-index: -1;
        width: 100%;
        height: 100%;
        pointer-events: none;
      }
    </style>

    <script>
      // ── Fondo de partículas (estrellas con drift + parallax de mouse) ──
      // Canvas 2D minimalista: ~60 partículas, pausado fuera de foco y con reduced-motion.
      function initStarfield() {
        const canvas = document.getElementById('starfield') as HTMLCanvasElement | null;
        if (!canvas || canvas.dataset.init) return;
        canvas.dataset.init = '1';

        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
        const dpr = Math.min(devicePixelRatio || 1, 2);
        let w = 0, h = 0;
        let raf = 0;
        let mx = 0.5, my = 0.5;

        type Star = { x: number; y: number; r: number; a: number; va: number; vx: number; vy: number; depth: number };
        let stars: Star[] = [];

        function resize() {
          w = innerWidth;
          h = innerHeight;
          canvas!.width = w * dpr;
          canvas!.height = h * dpr;
          ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
          const count = Math.min(90, Math.floor((w * h) / 22000));
          stars = Array.from({ length: count }, () => ({
            x: Math.random() * w,
            y: Math.random() * h,
            r: 0.6 + Math.random() * 1.5,
            a: 0.1 + Math.random() * 0.5,
            va: (Math.random() - 0.5) * 0.008,
            vx: (Math.random() - 0.5) * 0.08,
            vy: (Math.random() - 0.5) * 0.06,
            depth: 0.3 + Math.random() * 0.7,
          }));
        }

        function frame() {
          ctx!.clearRect(0, 0, w, h);
          const ox = (mx - 0.5) * 18;
          const oy = (my - 0.5) * 12;
          for (const s of stars) {
            s.x += s.vx;
            s.y += s.vy;
            s.a += s.va;
            if (s.a < 0.05 || s.a > 0.6) s.va *= -1;
            if (s.x < -5) s.x = w + 5;
            if (s.x > w + 5) s.x = -5;
            if (s.y < -5) s.y = h + 5;
            if (s.y > h + 5) s.y = -5;
            ctx!.beginPath();
            ctx!.arc(s.x + ox * s.depth, s.y + oy * s.depth, s.r, 0, Math.PI * 2);
            ctx!.fillStyle = `rgba(200, 236, 212, ${s.a})`;
            ctx!.fill();
          }
          raf = requestAnimationFrame(frame);
        }

        resize();
        addEventListener('resize', resize, { passive: true });
        addEventListener(
          'pointermove',
          (e) => {
            mx = e.clientX / w;
            my = e.clientY / h;
          },
          { passive: true }
        );

        if (reduced) {
          // Un solo frame estático
          ctx.clearRect(0, 0, w, h);
          for (const s of stars) {
            ctx.beginPath();
            ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
            ctx.fillStyle = `rgba(200, 236, 212, ${s.a})`;
            ctx.fill();
          }
          return;
        }

        document.addEventListener('visibilitychange', () => {
          if (document.hidden) cancelAnimationFrame(raf);
          else raf = requestAnimationFrame(frame);
        });
        raf = requestAnimationFrame(frame);
      }

      // ── Reveal on scroll ──
      function initReveal() {
        const els = document.querySelectorAll('[data-reveal]:not(.in)');
        if (!els.length) return;
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
        );
        els.forEach((el) => io.observe(el));
      }

      // ── Tilt 3D + glow que sigue al cursor (delegado, un solo listener) ──
      function initTilt() {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        if (matchMedia('(hover: none)').matches) return;
        if ((document.body as any).__tiltInit) return;
        (document.body as any).__tiltInit = true;

        document.body.addEventListener(
          'pointermove',
          (e) => {
            const el = (e.target as HTMLElement).closest<HTMLElement>('[data-tilt]');
            if (!el) return;
            const rect = el.getBoundingClientRect();
            const px = (e.clientX - rect.left) / rect.width;
            const py = (e.clientY - rect.top) / rect.height;
            el.style.setProperty('--mx', `${px * 100}%`);
            el.style.setProperty('--my', `${py * 100}%`);
            const rx = (0.5 - py) * 4;
            const ry = (px - 0.5) * 4;
            el.style.transform = `perspective(900px) rotateX(${rx}deg) rotateY(${ry}deg) translateZ(0)`;
          },
          { passive: true }
        );

        document.body.addEventListener(
          'pointerout',
          (e) => {
            const el = (e.target as HTMLElement).closest<HTMLElement>('[data-tilt]');
            if (el && !el.contains(e.relatedTarget as Node)) el.style.transform = '';
          },
          { passive: true }
        );
      }

      document.addEventListener('astro:page-load', () => {
        initStarfield();
        initReveal();
        initTilt();
      });
    </script>
  </body>
</html>
